#######################################################################
# Simulation Model Exchange - Version 1.4.1
# Fix: Restored missing PDM Property definitions (metadata, versionInfo, etc.)
# SPDX-License-Identifier: CC-BY-4.0
#######################################################################

@prefix samm: <urn:samm:org.eclipse.esmf.samm:meta-model:2.1.0#> .
@prefix samm-c: <urn:samm:org.eclipse.esmf.samm:characteristic:2.1.0#> .
@prefix : <urn:samm:io.catenax.simulation_model.minimal:1.4.0#> .

:SimulationModel a samm:Aspect ;
   samm:preferredName "Simulation Model"@en ;
   samm:description "Simulation model aspect regrouped by ProSTEP Smart SE categories."@en ;
   samm:version "1.4.0" ;
   samm:properties ( :simulationModelId
                     :pdmInformation
                     :modelInformation
                     :analysisSettings
                     :hardwareInformation
                     :results
                     :modelProperties
                     :simulationModelBinary
                     :requirementReferences ) ;
   samm:operations ( ) ;
   samm:events ( ) .

#######################################################################
# ROOT PROPERTIES
#######################################################################

:simulationModelId a samm:Property ;
   samm:preferredName "Simulation Model ID"@en ;
   samm:description "Unique identifier of this simulation model instance."@en ;
   samm:characteristic samm-c:Text ;
   samm:exampleValue "SIM-0001-THERMAL" .

:pdmInformation a samm:Property ;
   samm:preferredName "PDM Information"@en ;
   samm:description "Metadata, BOM structure, change info, version info, and configuration."@en ;
   samm:characteristic :PdmInformationCharacteristic .

:modelInformation a samm:Property ;
   samm:preferredName "Model Information"@en ;
   samm:description "Topology, Control, E/E, Software, Mechanics, Functions."@en ;
   samm:characteristic :ModelInformationCharacteristic .

:analysisSettings a samm:Property ;
   samm:preferredName "Analysis Settings"@en ;
   samm:description "Requirement links, Solver/General settings, Load/Boundary/Start conditions."@en ;
   samm:characteristic :AnalysisSettingsCharacteristic .

:hardwareInformation a samm:Property ;
   samm:preferredName "Hardware Information"@en ;
   samm:description "ECU and HIL description."@en ;
   samm:characteristic :HardwareInformationCharacteristic .

:results a samm:Property ;
   samm:preferredName "Results"@en ;
   samm:description "Key results, reports, and post processing."@en ;
   samm:characteristic :ResultsCharacteristic .

:modelProperties a samm:Property ;
   samm:preferredName "Properties"@en ;
   samm:description "General properties, Parameters, State variables, Characteristic diagrams."@en ;
   samm:characteristic :ModelPropertiesCharacteristic .

:simulationModelBinary a samm:Property ;
   samm:preferredName "Simulation Model Binary"@en ;
   samm:description "Reference to the binary representation with minimal extended metadata."@en ;
   samm:characteristic :BinaryModelCharacteristic .

:requirementReferences a samm:Property ;
   samm:preferredName "Requirement References"@en ;
   samm:description "Set of local requirement references."@en ;
   samm:characteristic :RequirementReferenceSet .

#######################################################################
# CHARACTERISTICS
#######################################################################

:PdmInformationCharacteristic a samm:Characteristic ;
   samm:preferredName "PDM Information Characteristic"@en ;
   samm:dataType :PdmInformationEntity .

:ModelInformationCharacteristic a samm:Characteristic ;
   samm:preferredName "Model Information Characteristic"@en ;
   samm:dataType :ModelInformationEntity .

:AnalysisSettingsCharacteristic a samm:Characteristic ;
   samm:preferredName "Analysis Settings Characteristic"@en ;
   samm:dataType :AnalysisSettingsEntity .

:HardwareInformationCharacteristic a samm:Characteristic ;
   samm:preferredName "Hardware Information Characteristic"@en ;
   samm:dataType :HardwareInformationEntity .

:ResultsCharacteristic a samm:Characteristic ;
   samm:preferredName "Results Characteristic"@en ;
   samm:dataType :ResultsEntity .

:ModelPropertiesCharacteristic a samm:Characteristic ;
   samm:preferredName "Model Properties Characteristic"@en ;
   samm:dataType :ModelPropertiesEntity .

:BinaryModelCharacteristic a samm:Characteristic ;
   samm:preferredName "Binary Model Characteristic"@en ;
   samm:dataType :BinaryModelEntity .

:RequirementReferenceSet a samm-c:Set ;
   samm:preferredName "Requirement Reference Set"@en ;
   samm:dataType :RequirementReferenceEntity .

#######################################################################
# ENTITIES (Level 1)
#######################################################################

:PdmInformationEntity a samm:Entity ;
   samm:preferredName "PDM Information"@en ;
   samm:properties ( :metadata :bomStructure :changeInfo :versionInfo :configuration ) .

:ModelInformationEntity a samm:Entity ;
   samm:preferredName "Model Information"@en ;
   samm:properties ( :topologyDescription :controlDescription :eeDescription :softwareDescription :mechanicsDescription :functionsDescription ) .

:AnalysisSettingsEntity a samm:Entity ;
   samm:preferredName "Analysis Settings"@en ;
   samm:properties ( :analysisRequirementLinks :solverSettingsText :generalSettingsText :loadCasesText :startConditionsText :boundaryConditionsText :testCasesText ) .

:HardwareInformationEntity a samm:Entity ;
   samm:preferredName "Hardware Information"@en ;
   samm:properties ( :ecuDescription :hilDescription ) .

:ResultsEntity a samm:Entity ;
   samm:preferredName "Results"@en ;
   samm:properties ( :keyResultsText :reportsText :postProcessingText ) .

:ModelPropertiesEntity a samm:Entity ;
   samm:preferredName "Model Properties"@en ;
   samm:properties ( :generalPropertiesText :parametersText :stateVariablesText :characteristicDiagramsText ) .

:BinaryModelEntity a samm:Entity ;
   samm:preferredName "Binary Model Entity"@en ;
   samm:properties ( :fileUri :fileType
                     [ samm:property :binarySize; samm:optional true ]
                     [ samm:property :checksumSha256; samm:optional true ] ) .

:RequirementReferenceEntity a samm:Entity ;
   samm:preferredName "Requirement Reference Entity"@en ;
   samm:properties ( :requirementId :requirementTitle ) .

#######################################################################
# PDM SUB-ENTITIES (Level 2)
#######################################################################

:MetadataEntity a samm:Entity ;
   samm:preferredName "Metadata"@en ;
   samm:description "Descriptive and governance metadata."@en ;
   samm:properties (
      :modelName
      :modelPurpose
      [ samm:property :author; samm:optional true ]
      [ samm:property :providerName; samm:optional true ]
      [ samm:property :physicalDomain; samm:optional true ]
      [ samm:property :micKeywords; samm:optional true ]
      [ samm:property :micConfidentiality; samm:optional true ]
      [ samm:property :micLicense; samm:optional true ]
      [ samm:property :micUseRestrictions; samm:optional true ]
      [ samm:property :micDocumentationUri; samm:optional true ]
      [ samm:property :micContact; samm:optional true ]
      [ samm:property :micOwner; samm:optional true ]
      [ samm:property :simulationType; samm:optional true ]
   ) .

:BomStructureEntity a samm:Entity ;
   samm:preferredName "BOM Structure"@en ;
   samm:properties (
      [ samm:property :relatedPartNumber; samm:optional true ]
      [ samm:property :relatedPartId; samm:optional true ]
   ) .

:ChangeInfoEntity a samm:Entity ;
   samm:preferredName "Change Information"@en ;
   samm:properties (
      [ samm:property :micCreatedAt; samm:optional true ]
      [ samm:property :micUpdatedAt; samm:optional true ]
      [ samm:property :micChangeLog; samm:optional true ]
   ) .

:VersionInfoEntity a samm:Entity ;
   samm:preferredName "Version Information"@en ;
   samm:properties (
      :modelVersion
      [ samm:property :micLifecycleState; samm:optional true ]
   ) .

:ConfigurationEntity a samm:Entity ;
   samm:preferredName "Configuration"@en ;
   samm:properties ( [ samm:property :configurationNotes; samm:optional true ] ) .

# --- PDM Property Definitions (The missing link!) ---

:metadata a samm:Property ;
   samm:preferredName "Metadata"@en ;
   samm:characteristic :MetadataCharacteristic .

:bomStructure a samm:Property ;
   samm:preferredName "BOM Structure"@en ;
   samm:characteristic :BomStructureCharacteristic .

:changeInfo a samm:Property ;
   samm:preferredName "Change Information"@en ;
   samm:characteristic :ChangeInfoCharacteristic .

:versionInfo a samm:Property ;
   samm:preferredName "Version Information"@en ;
   samm:characteristic :VersionInfoCharacteristic .

:configuration a samm:Property ;
   samm:preferredName "Configuration"@en ;
   samm:characteristic :ConfigurationCharacteristic .

# --- Characteristics for PDM Sub-Entities ---

:MetadataCharacteristic a samm:Characteristic ;
   samm:preferredName "Metadata Characteristic"@en ;
   samm:dataType :MetadataEntity .

:BomStructureCharacteristic a samm:Characteristic ;
   samm:preferredName "BOM Structure Characteristic"@en ;
   samm:dataType :BomStructureEntity .

:ChangeInfoCharacteristic a samm:Characteristic ;
   samm:preferredName "Change Info Characteristic"@en ;
   samm:dataType :ChangeInfoEntity .

:VersionInfoCharacteristic a samm:Characteristic ;
   samm:preferredName "Version Info Characteristic"@en ;
   samm:dataType :VersionInfoEntity .

:ConfigurationCharacteristic a samm:Characteristic ;
   samm:preferredName "Configuration Characteristic"@en ;
   samm:dataType :ConfigurationEntity .

#######################################################################
# PROPERTIES & DEFINITIONS
#######################################################################

# --- Metadata Fields ---
:modelName a samm:Property ;
   samm:preferredName "Model Name"@en ;
   samm:characteristic samm-c:Text .

:modelPurpose a samm:Property ;
   samm:preferredName "Model Purpose"@en ;
   samm:characteristic samm-c:Text .

:author a samm:Property ;
   samm:preferredName "Author"@en ;
   samm:characteristic samm-c:Text .

:providerName a samm:Property ;
   samm:preferredName "Provider Name"@en ;
   samm:characteristic samm-c:Text .

:physicalDomain a samm:Property ;
   samm:preferredName "Physical Domain"@en ;
   samm:characteristic samm-c:Text .

:simulationType a samm:Property ;
   samm:preferredName "Simulation Type"@en ;
   samm:characteristic samm-c:Text .

:micKeywords a samm:Property ;
   samm:preferredName "Keywords"@en ;
   samm:characteristic samm-c:Text .

:micConfidentiality a samm:Property ;
   samm:preferredName "Confidentiality"@en ;
   samm:characteristic samm-c:Text .

:micLicense a samm:Property ;
   samm:preferredName "License"@en ;
   samm:characteristic samm-c:Text .

:micUseRestrictions a samm:Property ;
   samm:preferredName "Use Restrictions"@en ;
   samm:characteristic samm-c:Text .

:micDocumentationUri a samm:Property ;
   samm:preferredName "Documentation URI"@en ;
   samm:characteristic samm-c:Text .

:micContact a samm:Property ;
   samm:preferredName "Contact"@en ;
   samm:characteristic samm-c:Text .

:micOwner a samm:Property ;
   samm:preferredName "Owner"@en ;
   samm:characteristic samm-c:Text .

:relatedPartNumber a samm:Property ;
   samm:preferredName "Related Part Number"@en ;
   samm:characteristic samm-c:Text .

:relatedPartId a samm:Property ;
   samm:preferredName "Related Part ID"@en ;
   samm:characteristic samm-c:Text .

:micCreatedAt a samm:Property ;
   samm:preferredName "Created At"@en ;
   samm:characteristic samm-c:Timestamp .

:micUpdatedAt a samm:Property ;
   samm:preferredName "Updated At"@en ;
   samm:characteristic samm-c:Timestamp .

:micChangeLog a samm:Property ;
   samm:preferredName "Change Log"@en ;
   samm:characteristic samm-c:Text .

:modelVersion a samm:Property ;
   samm:preferredName "Model Version"@en ;
   samm:characteristic :VersionTrait .

:micLifecycleState a samm:Property ;
   samm:preferredName "Lifecycle State"@en ;
   samm:characteristic samm-c:Text .

:configurationNotes a samm:Property ;
   samm:preferredName "Configuration Notes"@en ;
   samm:characteristic samm-c:Text .

:fileUri a samm:Property ;
   samm:preferredName "File URI"@en ;
   samm:characteristic samm-c:Text .

:fileType a samm:Property ;
   samm:preferredName "File Type"@en ;
   samm:characteristic samm-c:Text .

:binarySize a samm:Property ;
   samm:preferredName "Binary Size"@en ;
   samm:characteristic :NonNegativeIntegerTextTrait .

:checksumSha256 a samm:Property ;
   samm:preferredName "Checksum SHA-256"@en ;
   samm:characteristic :Sha256HexTextTrait .

:requirementId a samm:Property ;
   samm:preferredName "Requirement ID"@en ;
   samm:characteristic samm-c:Text .

:requirementTitle a samm:Property ;
   samm:preferredName "Requirement Title"@en ;
   samm:characteristic samm-c:Text .

# --- Simple Text Description Fields ---
:topologyDescription a samm:Property ; samm:characteristic samm-c:Text .
:controlDescription a samm:Property ; samm:characteristic samm-c:Text .
:eeDescription a samm:Property ; samm:characteristic samm-c:Text .
:softwareDescription a samm:Property ; samm:characteristic samm-c:Text .
:mechanicsDescription a samm:Property ; samm:characteristic samm-c:Text .
:functionsDescription a samm:Property ; samm:characteristic samm-c:Text .
:solverSettingsText a samm:Property ; samm:characteristic samm-c:Text .
:generalSettingsText a samm:Property ; samm:characteristic samm-c:Text .
:loadCasesText a samm:Property ; samm:characteristic samm-c:Text .
:startConditionsText a samm:Property ; samm:characteristic samm-c:Text .
:boundaryConditionsText a samm:Property ; samm:characteristic samm-c:Text .
:testCasesText a samm:Property ; samm:characteristic samm-c:Text .
:ecuDescription a samm:Property ; samm:characteristic samm-c:Text .
:hilDescription a samm:Property ; samm:characteristic samm-c:Text .
:keyResultsText a samm:Property ; samm:characteristic samm-c:Text .
:reportsText a samm:Property ; samm:characteristic samm-c:Text .
:postProcessingText a samm:Property ; samm:characteristic samm-c:Text .
:generalPropertiesText a samm:Property ; samm:characteristic samm-c:Text .
:parametersText a samm:Property ; samm:characteristic samm-c:Text .
:stateVariablesText a samm:Property ; samm:characteristic samm-c:Text .
:characteristicDiagramsText a samm:Property ; samm:characteristic samm-c:Text .
:analysisRequirementLinks a samm:Property ; samm:characteristic :RequirementReferenceSet .

# --- Traits ---
:VersionTrait a samm-c:Trait ;
   samm-c:baseCharacteristic samm-c:Text ;
   samm-c:constraint :SemanticVersionRegex .
:SemanticVersionRegex a samm-c:RegularExpressionConstraint ;
   samm:value "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-[\\w\\.]+)?(?:\\+[\\w\\.]+)?$" .
:NonNegativeIntegerRegex a samm-c:RegularExpressionConstraint ;
   samm:value "^[0-9]+$" .
:NonNegativeIntegerTextTrait a samm-c:Trait ;
   samm-c:baseCharacteristic samm-c:Text ;
   samm-c:constraint :NonNegativeIntegerRegex .
:Sha256HexRegex a samm-c:RegularExpressionConstraint ;
   samm:value "^[A-Fa-f0-9]{64}$" .
:Sha256HexTextTrait a samm-c:Trait ;
   samm-c:baseCharacteristic samm-c:Text ;
   samm-c:constraint :Sha256HexRegex .

#######################################################################
# Simulation Model Exchange - Version 1.5.1
# Fix: Removed external dependency on 'shared.uuid'. 
#      UUID trait is now defined locally to ensure import success.
# SPDX-License-Identifier: CC-BY-4.0
#######################################################################

@prefix samm: <urn:samm:org.eclipse.esmf.samm:meta-model:2.1.0#> .
@prefix samm-c: <urn:samm:org.eclipse.esmf.samm:characteristic:2.1.0#> .
@prefix samm-e: <urn:samm:org.eclipse.esmf.samm:entity:2.1.0#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix : <urn:samm:io.catenax.simulation_model.minimal:1.5.1#> .

:SimulationModel a samm:Aspect ;
   samm:preferredName "Simulation Model"@en ;
   samm:description "Simulation model aspect regrouped by ProSTEP Smart SE categories."@en ;
   samm:version "1.5.1" ;
   samm:properties ( :catenaXId
                     :pdmInformation
                     :modelInformation
                     :analysisSettings
                     :hardwareInformation
                     :results
                     :modelProperties
                     :simulationModelBinary
                     :requirementReferences ) ;
   samm:operations ( ) ;
   samm:events ( ) .

#######################################################################
# ROOT PROPERTIES
#######################################################################

:catenaXId a samm:Property ;
   samm:preferredName "Catena-X ID"@en ;
   samm:description "The Catena-X ID of this simulation model instance."@en ;
   samm:characteristic :UuidV4Trait ;
   samm:exampleValue "055c1128-0375-47c8-98de-7cf802c3241d" .

:simulationModelBinary a samm:Property ;
   samm:preferredName "Simulation Model Binaries"@en ;
   samm:description "Set of external binary model items associated with this simulation."@en ;
   samm:characteristic :SetOfExternalBinaryModelDataCharacteristic .

:pdmInformation a samm:Property ;
   samm:preferredName "PDM Information"@en ;
   samm:characteristic :PdmInformationCharacteristic .

:modelInformation a samm:Property ;
   samm:preferredName "Model Information"@en ;
   samm:characteristic :ModelInformationCharacteristic .

:analysisSettings a samm:Property ;
   samm:preferredName "Analysis Settings"@en ;
   samm:characteristic :AnalysisSettingsCharacteristic .

:hardwareInformation a samm:Property ;
   samm:preferredName "Hardware Information"@en ;
   samm:characteristic :HardwareInformationCharacteristic .

:results a samm:Property ;
   samm:preferredName "Results"@en ;
   samm:characteristic :ResultsCharacteristic .

:modelProperties a samm:Property ;
   samm:preferredName "Properties"@en ;
   samm:characteristic :ModelPropertiesCharacteristic .

:requirementReferences a samm:Property ;
   samm:preferredName "Requirement References"@en ;
   samm:characteristic :RequirementReferenceSet .

#######################################################################
# BINARY REFERENCE DEFINITIONS
#######################################################################

:SetOfExternalBinaryModelDataCharacteristic a samm-c:Set ;
   samm:preferredName "Set of External Binary Model Data"@en ;
   samm:dataType :ExternalBinaryModelDataEntity .

:ExternalBinaryModelDataEntity a samm:Entity ;
   samm:preferredName "External Binary Model Data"@en ;
   samm:properties ( :catenaXId
                     [ samm:property :semanticTags; samm:optional true ]
                     [ samm:property :customTags; samm:optional true ] ) .

:semanticTags a samm:Property ;
   samm:preferredName "Semantic Tags"@en ;
   samm:characteristic :SetOfTagsCharacteristic ;
   samm:exampleValue "FMU" .

:customTags a samm:Property ;
   samm:preferredName "Custom Tags"@en ;
   samm:characteristic :SetOfTagsCharacteristic ;
   samm:exampleValue "BatteryPack_V3" .

:SetOfTagsCharacteristic a samm-c:Set ;
   samm:preferredName "Set of Tags"@en ;
   samm:dataType xsd:string .

#######################################################################
# ENTITIES (Top Level)
#######################################################################

:PdmInformationEntity a samm:Entity ;
   samm:preferredName "PDM Information"@en ;
   samm:properties ( :metadata :bomStructure :changeInfo :versionInfo :configuration ) .

:ModelInformationEntity a samm:Entity ;
   samm:preferredName "Model Information"@en ;
   samm:properties ( :topologyDescription :controlDescription :eeDescription :softwareDescription :mechanicsDescription :functionsDescription ) .

:AnalysisSettingsEntity a samm:Entity ;
   samm:preferredName "Analysis Settings"@en ;
   samm:properties ( :analysisRequirementLinks :solverSettingsText :generalSettingsText :loadCasesText :startConditionsText :boundaryConditionsText :testCasesText ) .

:HardwareInformationEntity a samm:Entity ;
   samm:preferredName "Hardware Information"@en ;
   samm:properties ( :ecuDescription :hilDescription ) .

:ResultsEntity a samm:Entity ;
   samm:preferredName "Results"@en ;
   samm:properties ( :keyResultsText :reportsText :postProcessingText ) .

:ModelPropertiesEntity a samm:Entity ;
   samm:preferredName "Model Properties"@en ;
   samm:properties ( :generalPropertiesText :parametersText :stateVariablesText :characteristicDiagramsText ) .

:RequirementReferenceEntity a samm:Entity ;
   samm:preferredName "Requirement Reference Entity"@en ;
   samm:properties ( :requirementId :requirementTitle ) .

#######################################################################
# PDM SUB-ENTITIES & PROPERTIES
#######################################################################

:MetadataEntity a samm:Entity ;
   samm:preferredName "Metadata Entity"@en ;
   samm:properties ( :modelName :modelPurpose [ samm:property :author; samm:optional true ] [ samm:property :providerName; samm:optional true ] [ samm:property :physicalDomain; samm:optional true ] [ samm:property :micKeywords; samm:optional true ] [ samm:property :micConfidentiality; samm:optional true ] [ samm:property :micLicense; samm:optional true ] [ samm:property :micUseRestrictions; samm:optional true ] [ samm:property :micDocumentationUri; samm:optional true ] [ samm:property :micContact; samm:optional true ] [ samm:property :micOwner; samm:optional true ] [ samm:property :simulationType; samm:optional true ] ) .

:BomStructureEntity a samm:Entity ;
   samm:preferredName "BOM Structure Entity"@en ;
   samm:properties ( [ samm:property :relatedPartNumber; samm:optional true ] [ samm:property :relatedPartId; samm:optional true ] ) .

:ChangeInfoEntity a samm:Entity ;
   samm:preferredName "Change Information Entity"@en ;
   samm:properties ( [ samm:property :micCreatedAt; samm:optional true ] [ samm:property :micUpdatedAt; samm:optional true ] [ samm:property :micChangeLog; samm:optional true ] ) .

:VersionInfoEntity a samm:Entity ;
   samm:preferredName "Version Information Entity"@en ;
   samm:properties ( :modelVersion [ samm:property :micLifecycleState; samm:optional true ] ) .

:ConfigurationEntity a samm:Entity ;
   samm:preferredName "Configuration Entity"@en ;
   samm:properties ( [ samm:property :configurationNotes; samm:optional true ] ) .

:metadata a samm:Property ; samm:characteristic :MetadataCharacteristic .
:bomStructure a samm:Property ; samm:characteristic :BomStructureCharacteristic .
:changeInfo a samm:Property ; samm:characteristic :ChangeInfoCharacteristic .
:versionInfo a samm:Property ; samm:characteristic :VersionInfoCharacteristic .
:configuration a samm:Property ; samm:characteristic :ConfigurationCharacteristic .

#######################################################################
# CHARACTERISTICS (Linking Entities)
#######################################################################

:PdmInformationCharacteristic a samm:Characteristic ; samm:dataType :PdmInformationEntity .
:ModelInformationCharacteristic a samm:Characteristic ; samm:dataType :ModelInformationEntity .
:AnalysisSettingsCharacteristic a samm:Characteristic ; samm:dataType :AnalysisSettingsEntity .
:HardwareInformationCharacteristic a samm:Characteristic ; samm:dataType :HardwareInformationEntity .
:ResultsCharacteristic a samm:Characteristic ; samm:dataType :ResultsEntity .
:ModelPropertiesCharacteristic a samm:Characteristic ; samm:dataType :ModelPropertiesEntity .
:RequirementReferenceSet a samm-c:Set ; samm:dataType :RequirementReferenceEntity .

:MetadataCharacteristic a samm:Characteristic ; samm:dataType :MetadataEntity .
:BomStructureCharacteristic a samm:Characteristic ; samm:dataType :BomStructureEntity .
:ChangeInfoCharacteristic a samm:Characteristic ; samm:dataType :ChangeInfoEntity .
:VersionInfoCharacteristic a samm:Characteristic ; samm:dataType :VersionInfoEntity .
:ConfigurationCharacteristic a samm:Characteristic ; samm:dataType :ConfigurationEntity .

#######################################################################
# ATOMIC PROPERTIES
#######################################################################

:modelName a samm:Property ; samm:characteristic samm-c:Text .
:modelPurpose a samm:Property ; samm:characteristic samm-c:Text .
:author a samm:Property ; samm:characteristic samm-c:Text .
:providerName a samm:Property ; samm:characteristic samm-c:Text .
:physicalDomain a samm:Property ; samm:characteristic samm-c:Text .
:simulationType a samm:Property ; samm:characteristic samm-c:Text .
:micKeywords a samm:Property ; samm:characteristic samm-c:Text .
:micConfidentiality a samm:Property ; samm:characteristic samm-c:Text .
:micLicense a samm:Property ; samm:characteristic samm-c:Text .
:micUseRestrictions a samm:Property ; samm:characteristic samm-c:Text .
:micDocumentationUri a samm:Property ; samm:characteristic samm-c:Text .
:micContact a samm:Property ; samm:characteristic samm-c:Text .
:micOwner a samm:Property ; samm:characteristic samm-c:Text .
:relatedPartNumber a samm:Property ; samm:characteristic samm-c:Text .
:relatedPartId a samm:Property ; samm:characteristic samm-c:Text .
:micCreatedAt a samm:Property ; samm:characteristic samm-c:Timestamp .
:micUpdatedAt a samm:Property ; samm:characteristic samm-c:Timestamp .
:micChangeLog a samm:Property ; samm:characteristic samm-c:Text .
:modelVersion a samm:Property ; samm:characteristic :VersionTrait .
:micLifecycleState a samm:Property ; samm:characteristic samm-c:Text .
:configurationNotes a samm:Property ; samm:characteristic samm-c:Text .
:requirementId a samm:Property ; samm:characteristic samm-c:Text .
:requirementTitle a samm:Property ; samm:characteristic samm-c:Text .

:topologyDescription a samm:Property ; samm:characteristic samm-c:Text .
:controlDescription a samm:Property ; samm:characteristic samm-c:Text .
:eeDescription a samm:Property ; samm:characteristic samm-c:Text .
:softwareDescription a samm:Property ; samm:characteristic samm-c:Text .
:mechanicsDescription a samm:Property ; samm:characteristic samm-c:Text .
:functionsDescription a samm:Property ; samm:characteristic samm-c:Text .
:solverSettingsText a samm:Property ; samm:characteristic samm-c:Text .
:generalSettingsText a samm:Property ; samm:characteristic samm-c:Text .
:loadCasesText a samm:Property ; samm:characteristic samm-c:Text .
:startConditionsText a samm:Property ; samm:characteristic samm-c:Text .
:boundaryConditionsText a samm:Property ; samm:characteristic samm-c:Text .
:testCasesText a samm:Property ; samm:characteristic samm-c:Text .
:ecuDescription a samm:Property ; samm:characteristic samm-c:Text .
:hilDescription a samm:Property ; samm:characteristic samm-c:Text .
:keyResultsText a samm:Property ; samm:characteristic samm-c:Text .
:reportsText a samm:Property ; samm:characteristic samm-c:Text .
:postProcessingText a samm:Property ; samm:characteristic samm-c:Text .
:generalPropertiesText a samm:Property ; samm:characteristic samm-c:Text .
:parametersText a samm:Property ; samm:characteristic samm-c:Text .
:stateVariablesText a samm:Property ; samm:characteristic samm-c:Text .
:characteristicDiagramsText a samm:Property ; samm:characteristic samm-c:Text .
:analysisRequirementLinks a samm:Property ; samm:characteristic :RequirementReferenceSet .

#######################################################################
# TRAITS AND CONSTRAINTS (Defined Locally)
#######################################################################

:VersionTrait a samm-c:Trait ;
   samm:preferredName "Version Trait"@en ;
   samm-c:baseCharacteristic samm-c:Text ;
   samm-c:constraint :SemanticVersionRegex .

:SemanticVersionRegex a samm-c:RegularExpressionConstraint ;
   samm:preferredName "Semantic Version Regex"@en ;
   samm:value "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-[\\w\\.]+)?(?:\\+[\\w\\.]+)?$" .

# --- NEW: Locally defined UUID Trait ---

:UuidV4Trait a samm-c:Trait ;
   samm:preferredName "UUID v4 Trait"@en ;
   samm:description "A trait ensuring the string is a valid UUID v4."@en ;
   samm-c:baseCharacteristic samm-c:Text ;
   samm-c:constraint :UuidV4RegularExpression .

:UuidV4RegularExpression a samm-c:RegularExpressionConstraint ;
   samm:preferredName "UUID v4 Regular Expression"@en ;
   samm:description "Regular expression for a UUID v4."@en ;
   samm:value "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-4[0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" .
